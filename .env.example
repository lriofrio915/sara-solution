# =============================================================
# Sara Medical — Variables de entorno
# Copia este archivo a .env y completa los valores.
# NUNCA subas .env al repositorio.
# =============================================================

# ── Base de datos (Supabase) ──────────────────────────────────
# Supabase → Project Settings → Database → Connection string
# Usar URL con pooler (Transaction mode) para Next.js / serverless
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Usar URL directa para migraciones (prisma db push)
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ── Supabase Auth ─────────────────────────────────────────────
# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # NUNCA exponer en el cliente

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://tu-dominio.com   # o http://localhost:3001 en dev
INTERNAL_APP_URL=http://localhost:3001
ADMIN_EMAILS=tu@email.com,otro@email.com     # separados por coma

# ── Sara IA (OpenRouter → Anthropic) ─────────────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=anthropic/claude-3-5-sonnet          # o el modelo que prefieras

# ── Facturación — Hotmart ─────────────────────────────────────
# Hotmart → Mis Productos → ID del producto (número)
HOTMART_PRODUCT_ID_MONTHLY=12345678    # ID del producto Pro Mensual
HOTMART_PRODUCT_ID_ANNUAL=87654321     # ID del producto Pro Anual
# Hotmart → Configuración → Webhooks → Hottok (secreto de verificación)
HOTMART_HOTTOK=tu_hottok_secreto

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Webhooks internos ─────────────────────────────────────────
CRON_SECRET=un_secreto_aleatorio_largo       # para proteger rutas /api/cron/*
LEADS_WEBHOOK_SECRET=otro_secreto_largo      # para webhook de leads de n8n

# ── WhatsApp (Evolution API) ──────────────────────────────────
EVOLUTION_API_URL=https://evolution.tu-dominio.com
EVOLUTION_API_KEY=tu_api_key
EVOLUTION_INSTANCE_NAME=sara
WHATSAPP_API_SECRET=secreto_para_webhook_whatsapp

# ── Marketing — Meta (Facebook/Instagram) ────────────────────
META_APP_ID=tu_app_id
META_APP_SECRET=tu_app_secret

# ── Marketing — LinkedIn ──────────────────────────────────────
LINKEDIN_CLIENT_ID=tu_client_id
LINKEDIN_CLIENT_SECRET=tu_client_secret

# ── ICD-11 (diagnósticos) ─────────────────────────────────────
ICD_CLIENT_ID=tu_client_id
ICD_CLIENT_SECRET=tu_client_secret

# ── Firma digital (Ecuador — firma.ec) ───────────────────────
FIRMA_EC_MASTER_KEY=tu_master_key

# ── Timestamp Authority (firma de documentos) ────────────────
TSA_URL=http://timestamp.digicert.com

# ── Opcionales ────────────────────────────────────────────────
BRAVE_API_KEY=         # para búsquedas web desde Sara IA
CHROME_PATH=           # ruta a Chrome para generación de PDFs (prod)
