// ============================================================
//  MedSara - Prisma Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ──────────────────────────────────────────────────

enum Plan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentType {
  IN_PERSON
  TELECONSULT
  HOME_VISIT
  EMERGENCY
  FOLLOW_UP
}

enum BloodType {
  A_POS
  A_NEG
  B_POS
  B_NEG
  AB_POS
  AB_NEG
  O_POS
  O_NEG
  UNKNOWN
}

enum PostStatus {
  DRAFT
  APPROVED
  REJECTED
  SCHEDULED
  PUBLISHED
  FAILED
}

enum ContentType {
  POST
  CAROUSEL
  REEL
  STORY
}

enum SocialPlatform {
  INSTAGRAM
  FACEBOOK
  BOTH
}

// ─── Doctor ─────────────────────────────────────────────────

model Doctor {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  specialty String
  email     String   @unique
  phone     String?
  plan      Plan     @default(FREE)
  active    Boolean  @default(true)
  avatarUrl String?
  bio       String?
  address   String?
  whatsapp    String?   // WhatsApp Business — Agente Sara IA
  webhookUrl  String?   // n8n webhook personalizado del médico
  branches    String?   // JSON: [{name, address}] sucursales adicionales
  schedules String?
  services  String?
  appointmentDuration Int @default(30)
  authId String? @unique
  prescriptionCounter Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patients               Patient[]
  appointments           Appointment[]
  medicalRecords         MedicalRecord[]
  prescriptions          Prescription[]
  examOrders             ExamOrder[]
  medicalCertificates    MedicalCertificate[]
  saraConversations      SaraConversation[]
  reminders              Reminder[]
  socialPosts            SocialPost[]
  knowledgeDocuments     KnowledgeDocument[]
  availabilitySchedules  AvailabilitySchedule[]
  brandProfile           BrandProfile?
  brandImages            BrandImage[]
  contentCalendars       ContentCalendar[]
  patientCharts          PatientChart[]
  attentions             Attention[]

  @@index([slug])
  @@index([email])
}

// ─── Availability Schedule ───────────────────────────────────

model AvailabilitySchedule {
  id        String  @id @default(cuid())
  doctorId  String
  weekday   Int
  startTime String
  endTime   String
  isActive  Boolean @default(true)
  location  String? // Centro médico donde atiende ese día

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId, weekday])
  @@index([doctorId])
}

// ─── Patient ────────────────────────────────────────────────

model Patient {
  id         String    @id @default(cuid())
  doctorId   String
  authId     String?   @unique
  name       String
  email      String?
  phone      String?
  birthDate  DateTime?
  bloodType  BloodType @default(UNKNOWN)
  allergies  String[]
  notes      String?
  avatarUrl  String?
  documentId   String?
  documentType String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor              Doctor              @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointments        Appointment[]
  medicalRecords      MedicalRecord[]
  prescriptions       Prescription[]
  examOrders          ExamOrder[]
  medicalCertificates MedicalCertificate[]
  saraConversations   SaraConversation[]
  chart               PatientChart?
  attentions          Attention[]

  @@index([doctorId])
  @@index([email])
  @@index([doctorId, name])
}

// ─── Appointment ────────────────────────────────────────────

model Appointment {
  id        String            @id @default(cuid())
  doctorId  String
  patientId String
  date      DateTime
  duration  Int               @default(30)
  status    AppointmentStatus @default(SCHEDULED)
  type      AppointmentType   @default(IN_PERSON)
  notes     String?
  reason    String?
  location  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor              Doctor               @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient             Patient              @relation(fields: [patientId], references: [id], onDelete: Cascade)
  prescriptions       Prescription[]
  examOrders          ExamOrder[]
  medicalCertificates MedicalCertificate[]

  @@index([doctorId])
  @@index([patientId])
  @@index([doctorId, date])
  @@index([status])
}

// ─── Medical Record ─────────────────────────────────────────

model MedicalRecord {
  id          String   @id @default(cuid())
  patientId   String
  doctorId    String
  diagnosis   String
  treatment   String?
  notes       String?
  symptoms    String[]
  vitalSigns  Json?
  attachments String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([doctorId])
  @@index([createdAt])
}

// ─── Prescription (Recetario) ────────────────────────────────

model Prescription {
  id            String    @id @default(cuid())
  rxNumber      String?
  patientId     String
  doctorId      String
  appointmentId String?
  date          DateTime  @default(now())
  medications   Json      // [{ name, dose, frequency, duration, notes }]
  instructions  String?   @db.Text  // INDICACIONES (right column)
  diagnosis     String?
  issuedAt      DateTime  @default(now())
  expiresAt     DateTime?
  pdfUrl        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor      Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([doctorId])
  @@index([appointmentId])
  @@index([date])
}

// ─── Exam Order (Orden de Examen) ────────────────────────────

model ExamOrder {
  id            String   @id @default(cuid())
  patientId     String
  doctorId      String
  appointmentId String?
  date          DateTime @default(now())
  exams         Json     // { hematologia: [...], bioquimica: [...], ... }
  otrosExams    String?  @db.Text
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor      Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([doctorId])
  @@index([appointmentId])
  @@index([doctorId, date])
}

// ─── Medical Certificate (Certificado Médico) ────────────────

model MedicalCertificate {
  id            String   @id @default(cuid())
  patientId     String
  doctorId      String
  appointmentId String?
  date          DateTime @default(now())
  content       String   @db.Text
  diagnosis     String?
  treatment     String?
  restDays      Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor      Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([doctorId])
  @@index([appointmentId])
  @@index([doctorId, date])
}

// ─── Sara Conversation ──────────────────────────────────────

model SaraConversation {
  id        String   @id @default(cuid())
  doctorId  String
  patientId String?
  messages  Json
  context   String?
  title     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor  Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([doctorId])
  @@index([patientId])
  @@index([doctorId, createdAt])
}

// ─── Reminder ───────────────────────────────────────────────

model Reminder {
  id          String   @id @default(cuid())
  doctorId    String
  title       String
  description String?
  dueDate     DateTime
  completed   Boolean  @default(false)
  completedAt DateTime?
  priority    String   @default("MEDIUM")
  category    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([doctorId, dueDate])
  @@index([completed])
}

// ─── Knowledge Document ─────────────────────────────────────

model KnowledgeDocument {
  id          String   @id @default(cuid())
  doctorId    String
  name        String
  size        Int
  mimeType    String
  storagePath String
  textContent String   @db.Text
  createdAt   DateTime @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([doctorId, createdAt])
}

// ─── Social Post ────────────────────────────────────────────

model SocialPost {
  id             String         @id @default(cuid())
  doctorId       String
  content        String         @db.Text
  imageUrl       String?
  platforms      Json
  publishedAt    DateTime?
  scheduledAt    DateTime?
  approvedAt     DateTime?
  status         PostStatus     @default(DRAFT)
  hashtags       String[]
  externalIds    Json?
  // Marketing fields
  contentType    ContentType    @default(POST)
  targetPlatform SocialPlatform @default(INSTAGRAM)
  topic          String?
  carouselSlides Json?
  reelScript     String?        @db.Text
  imagePrompt    String?
  suggestedTime  String?
  aiGenerated    Boolean        @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor        Doctor         @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  calendarItems CalendarItem[]

  @@index([doctorId])
  @@index([status])
  @@index([contentType])
  @@index([publishedAt])
  @@index([doctorId, status])
}

// ─── Brand Profile ──────────────────────────────────────────

model BrandProfile {
  id             String   @id @default(cuid())
  doctorId       String   @unique
  clinicName     String?
  specialties    String[]
  slogan         String?
  primaryColor   String   @default("#2563EB")
  secondaryColor String   @default("#0D9488")
  accentColor    String   @default("#F59E0B")
  logoUrl        String?
  logoPath       String?
  tones          String[]
  targetAudience String?  @db.Text
  excludedTopics String?  @db.Text
  instagramUrl   String?
  facebookUrl    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  images BrandImage[]

  @@index([doctorId])
}

// ─── Brand Image ────────────────────────────────────────────

model BrandImage {
  id             String  @id @default(cuid())
  doctorId       String
  brandProfileId String
  url            String
  storagePath    String
  category       String
  description    String?

  createdAt DateTime @default(now())

  doctor       Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  brandProfile BrandProfile @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([brandProfileId])
  @@index([category])
}

// ─── Content Calendar ───────────────────────────────────────

model ContentCalendar {
  id        String   @id @default(cuid())
  doctorId  String
  title     String
  startDate DateTime
  endDate   DateTime
  frequency String   @default("MONTHLY")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor Doctor         @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  items  CalendarItem[]

  @@index([doctorId])
}

// ─── Calendar Item ──────────────────────────────────────────

model CalendarItem {
  id            String   @id @default(cuid())
  calendarId    String
  socialPostId  String
  scheduledDate DateTime
  order         Int      @default(0)

  createdAt DateTime @default(now())

  calendar   ContentCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  socialPost SocialPost      @relation(fields: [socialPostId], references: [id], onDelete: Cascade)

  @@index([calendarId])
  @@index([socialPostId])
  @@index([scheduledDate])
}

// ─── Patient Chart (Ficha Clínica Permanente) ────────────────
model PatientChart {
  id        String @id @default(cuid())
  patientId String @unique
  doctorId  String

  // Datos personales extendidos
  sex           String?
  maritalStatus String?
  education     String?
  province      String?
  city          String?
  category      String?
  occupation    String?
  referredBy    String?
  address       String?
  admissionDate DateTime?
  insurance     String?
  patientStatus String? // AMBULATORIO | HOSPITALARIO | FALLECIDO

  // Alertas (mostrar en rojo si tienen contenido)
  alert1 String?
  alert2 String?
  alert3 String?

  // Tutor / Representante
  tutorName     String?
  tutorRelation String?
  tutorPhone    String?
  tutorEmail    String?

  // Antecedentes como JSON flexible
  heredoFamiliar        Json?
  personalPathologic    Json?
  personalNonPathologic Json?
  gynecoObstetric       Json?
  dentalHabits          Json?
  stimulation           Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([doctorId])
}

// ─── Attention (Consulta Clínica) ────────────────────────────
model Attention {
  id        String   @id @default(cuid())
  patientId String
  doctorId  String

  // Datos generales de la consulta
  establishment   String?
  service         String? // Consulta | Emergencia | Hospitalización
  attentionType   String?
  insurance       String?
  datetime        DateTime @default(now())
  nextAppointment DateTime?
  durationMins    Int?

  // Motivo y evolución
  motive    String? @db.Text
  evolution String? @db.Text

  // Sub-secciones clínicas (JSON flexible)
  exploration      Json? // signos vitales + exploración regional
  diagnoses        Json? // [{cie10Code, cie10Desc, observations, isNew, isDefinitive}]
  prescriptionData Json? // [{medicine, quantity, indications}] + validUntil + notes
  exams            Json? // {hematologico: [], bioquimico: [], ...}
  images           Json? // [{url, description}]
  billing          Json? // [{description, quantity, unitPrice}]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([doctorId])
  @@index([doctorId, datetime])
}
